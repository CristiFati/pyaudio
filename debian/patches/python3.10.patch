Description: Adjust Makefile for Python 3.10
 import get_platform() from sysconfig instead of distutils
 support Python with 2-digit minor version
Author: Graham Inggs <ginggs@debian.org>
Last-Update: 2022-07-20

--- a/Makefile
+++ b/Makefile
@@ -7,7 +7,7 @@
 BUILD_ARGS ?=
 SPHINX ?= sphinx-build
 DOCS_OUTPUT=docs/
-PYTHON_BUILD_DIR:=$(shell $(PYTHON) -c "import distutils.util; import sys; print(f'{distutils.util.get_platform()}-{sys.version_info[0]}.{sys.version_info[1]}')")
+PYTHON_BUILD_DIR:=$(shell $(PYTHON) -c "import sysconfig; import sys; print(f'{sysconfig.get_platform()}-{sys.version_info[0]}.{sys.version_info[1]}')")
 BUILD_DIR:=lib.$(PYTHON_BUILD_DIR)
 BUILD_STAMP:=$(BUILD_DIR)/build
 SRCFILES := src/*.c src/*.h src/*.py
